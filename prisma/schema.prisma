generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  parentName String
  phone      String
  email      String
  class      String
  subject    String
  location   String
  timing     String?
  message    String?
  honeypot   String?
  createdAt  DateTime @default(now())

  @@map("leads")
}

model Tutor {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String
  qualification String
  experience    String
  subjects      String
  location      String
  resume        String?
  message       String?
  createdAt     DateTime @default(now())

  @@map("tutors")
}
